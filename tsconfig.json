{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "entrypoints/**/*.ts",
    "entrypoints/**/*.vue",
    "api/**/*.ts",
    "stores/**/*.ts",
    "utils/**/*.ts",
    "env.d.ts",
    ".wxt/wxt.d.ts"
  ],
  "exclude": ["node_modules", "dist", "dist_firefox", ".output"]
}
